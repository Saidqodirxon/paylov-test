<!DOCTYPE html>
<html lang="uz">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:       #0f172a;
      --surface:  #1e293b;
      --surface2: #162032;
      --border:   #334155;
      --text:     #e2e8f0;
      --muted:    #94a3b8;
      --accent:   #38bdf8;
      --accent2:  #0284c7;
      --success:  #86efac;
      --success-bg: #166534;
      --danger:   #f87171;
      --danger-bg: #7f1d1d;
      --warning:  #fde68a;
    }

    body {
      font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      line-height: 1.5;
    }

    a { text-decoration: none; color: inherit; }

    /* ── NAV ─────────────────────────────────────────────────── */
    .topnav {
      background: var(--surface2);
      border-bottom: 1px solid var(--border);
      padding: 0 24px;
      display: flex;
      align-items: center;
      gap: 8px;
      height: 56px;
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .nav-logo {
      font-size: 1rem;
      font-weight: 700;
      color: var(--accent);
      letter-spacing: -0.02em;
      margin-right: 16px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .nav-logo svg { width: 22px; height: 22px; }

    .nav-links {
      display: flex;
      gap: 4px;
      flex: 1;
    }

    .nav-link {
      padding: 6px 14px;
      border-radius: 8px;
      font-size: 0.85rem;
      font-weight: 500;
      color: var(--muted);
      transition: all 0.15s;
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .nav-link:hover { color: var(--text); background: rgba(255,255,255,0.05); }
    .nav-link.active { color: var(--accent); background: rgba(56,189,248,0.08); }

    .nav-badge {
      font-size: 0.65rem;
      background: var(--accent2);
      color: #fff;
      padding: 1px 5px;
      border-radius: 99px;
      font-weight: 600;
    }

    .nav-env {
      margin-left: auto;
      font-size: 0.72rem;
      background: var(--border);
      padding: 3px 9px;
      border-radius: 99px;
      color: var(--muted);
    }

    /* ── PAGE WRAPPER ─────────────────────────────────────────── */
    .page { max-width: 1100px; margin: 0 auto; padding: 32px 20px 64px; }

    /* ── PAGE HEADER ─────────────────────────────────────────── */
    .page-header { margin-bottom: 28px; }
    .page-header h1 { font-size: 1.45rem; font-weight: 700; color: var(--text); }
    .page-header p { color: var(--muted); font-size: 0.875rem; margin-top: 4px; }

    /* ── CARDS ───────────────────────────────────────────────── */
    .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 18px; }
    .grid-3 { grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); }

    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 14px;
      overflow: hidden;
    }

    .card-header {
      padding: 13px 18px;
      background: var(--surface2);
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .card-title { font-size: 0.9rem; font-weight: 600; }
    .card-path  { font-size: 0.72rem; color: var(--muted); margin-left: auto; font-family: monospace; }

    .card-body { padding: 18px; display: flex; flex-direction: column; gap: 12px; }

    /* ── METHOD BADGES ───────────────────────────────────────── */
    .badge {
      font-size: 0.65rem; font-weight: 700;
      padding: 2px 7px; border-radius: 5px;
      letter-spacing: 0.06em;
    }
    .badge-post { background: #166534; color: #bbf7d0; }
    .badge-get  { background: #1e3a8a; color: #bfdbfe; }
    .badge-del  { background: #7f1d1d; color: #fecaca; }

    /* ── FORMS ───────────────────────────────────────────────── */
    .field { display: flex; flex-direction: column; gap: 5px; }
    .field label { font-size: 0.75rem; color: var(--muted); font-weight: 500; }

    input, textarea, select {
      background: var(--bg);
      border: 1px solid var(--border);
      color: var(--text);
      padding: 9px 12px;
      border-radius: 8px;
      font-size: 0.85rem;
      width: 100%;
      font-family: inherit;
      transition: border-color 0.15s;
    }

    input:focus, textarea:focus, select:focus {
      outline: none;
      border-color: var(--accent);
      box-shadow: 0 0 0 3px rgba(56,189,248,0.1);
    }

    input::placeholder, textarea::placeholder { color: #475569; }
    textarea { resize: vertical; min-height: 72px; font-family: monospace; font-size: 0.78rem; }

    /* ── BUTTONS ─────────────────────────────────────────────── */
    .btn {
      border: none; border-radius: 8px;
      padding: 9px 16px; font-size: 0.85rem; font-weight: 600;
      cursor: pointer; width: 100%; margin-top: 2px;
      transition: all 0.15s; display: flex;
      align-items: center; justify-content: center; gap: 6px;
    }
    .btn:disabled { opacity: 0.5; cursor: not-allowed; }

    .btn-primary { background: var(--accent2); color: #fff; }
    .btn-primary:hover:not(:disabled) { background: #0369a1; }

    .btn-danger { background: #991b1b; color: #fff; }
    .btn-danger:hover:not(:disabled) { background: #b91c1c; }

    .btn-success { background: #15803d; color: #fff; }
    .btn-success:hover:not(:disabled) { background: #166534; }

    .btn-outline {
      background: transparent;
      border: 1px solid var(--border);
      color: var(--muted);
    }
    .btn-outline:hover { border-color: var(--accent); color: var(--accent); }

    /* ── RESPONSE BOX ────────────────────────────────────────── */
    .resp {
      background: #060d1a;
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 10px 13px;
      font-family: 'Consolas', 'Courier New', monospace;
      font-size: 0.73rem;
      white-space: pre-wrap;
      word-break: break-all;
      color: var(--muted);
      display: none;
      max-height: 220px;
      overflow-y: auto;
      line-height: 1.6;
    }
    .resp.ok  { color: var(--success); border-color: #166534; }
    .resp.err { color: var(--danger);  border-color: #7f1d1d; }
    .resp.show { display: block; }

    /* ── DIVIDER ─────────────────────────────────────────────── */
    .divider {
      display: flex; align-items: center; gap: 12px;
      color: #475569; font-size: 0.78rem; font-weight: 600;
      letter-spacing: 0.04em; text-transform: uppercase;
      margin: 8px 0 4px;
      grid-column: 1 / -1;
    }
    .divider::before, .divider::after {
      content: ''; flex: 1; height: 1px; background: var(--border);
    }

    /* ── STEPS ───────────────────────────────────────────────── */
    .steps { display: flex; gap: 0; margin-bottom: 20px; }
    .step {
      display: flex; align-items: center; gap: 8px;
      font-size: 0.8rem; color: var(--muted); flex: 1;
    }
    .step:not(:last-child)::after {
      content: ''; flex: 1; height: 1px;
      background: var(--border); margin: 0 4px;
    }
    .step-num {
      width: 24px; height: 24px; border-radius: 50%;
      background: var(--surface2); border: 1px solid var(--border);
      display: flex; align-items: center; justify-content: center;
      font-size: 0.7rem; font-weight: 700; flex-shrink: 0;
    }
    .step.active .step-num { background: var(--accent2); border-color: var(--accent); color: #fff; }
    .step.done .step-num   { background: var(--success-bg); border-color: var(--success); color: var(--success); }
    .step.active { color: var(--text); }
    .step.done   { color: var(--success); }

    /* ── ALERT ───────────────────────────────────────────────── */
    .alert {
      padding: 10px 14px; border-radius: 8px;
      font-size: 0.82rem; display: none;
    }
    .alert.show { display: block; }
    .alert-info    { background: rgba(56,189,248,0.1); border: 1px solid rgba(56,189,248,0.3); color: var(--accent); }
    .alert-success { background: rgba(134,239,172,0.1); border: 1px solid #166534; color: var(--success); }
    .alert-danger  { background: rgba(248,113,113,0.1); border: 1px solid #7f1d1d; color: var(--danger); }

    /* ── COPY BUTTON ─────────────────────────────────────────── */
    .copy-row { display: flex; gap: 8px; align-items: center; }
    .copy-row input { flex: 1; }
    .btn-copy {
      background: var(--surface2); border: 1px solid var(--border);
      color: var(--muted); padding: 9px 14px; border-radius: 8px;
      cursor: pointer; font-size: 0.8rem; font-weight: 600;
      white-space: nowrap; transition: all 0.15s; flex-shrink: 0;
    }
    .btn-copy:hover { border-color: var(--accent); color: var(--accent); }

    /* ── LOADER ─────────────────────────────────────────────── */
    .spinner {
      width: 14px; height: 14px; border-radius: 50%;
      border: 2px solid rgba(255,255,255,0.3);
      border-top-color: #fff;
      animation: spin 0.6s linear infinite;
      display: none;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* ── STATUS DOT ─────────────────────────────────────────── */
    .dot {
      width: 8px; height: 8px; border-radius: 50%;
      background: var(--muted); display: inline-block;
    }
    .dot.green { background: var(--success); box-shadow: 0 0 0 2px rgba(134,239,172,0.2); }
    .dot.red   { background: var(--danger); box-shadow: 0 0 0 2px rgba(248,113,113,0.2); }

    /* ── FOOTER ─────────────────────────────────────────────── */
    .footer {
      border-top: 1px solid var(--border);
      padding: 16px 24px;
      text-align: center;
      font-size: 0.75rem;
      color: #334155;
    }

    /* ── DASHBOARD CARDS ─────────────────────────────────────── */
    .stat-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 20px;
      display: flex;
      gap: 14px;
      align-items: flex-start;
    }
    .stat-icon {
      width: 40px; height: 40px; border-radius: 10px;
      background: var(--surface2);
      display: flex; align-items: center; justify-content: center;
      font-size: 1.2rem; flex-shrink: 0;
    }
    .stat-label { font-size: 0.75rem; color: var(--muted); }
    .stat-title { font-size: 1rem; font-weight: 600; margin-top: 2px; }
    .stat-desc  { font-size: 0.8rem; color: var(--muted); margin-top: 4px; }

    /* ── QUICK ACTION ─────────────────────────────────────────── */
    .qa-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 20px 22px;
      cursor: pointer;
      transition: all 0.15s;
      display: block;
    }
    .qa-card:hover {
      border-color: var(--accent);
      transform: translateY(-1px);
      box-shadow: 0 4px 20px rgba(56,189,248,0.08);
    }
    .qa-icon { font-size: 1.6rem; margin-bottom: 10px; }
    .qa-title { font-size: 0.95rem; font-weight: 600; }
    .qa-desc  { font-size: 0.78rem; color: var(--muted); margin-top: 4px; }
    .qa-arrow { color: var(--accent); font-size: 0.8rem; margin-top: 12px; }

    /* ── HEALTH BAR ──────────────────────────────────────────── */
    .health-bar {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 14px 20px;
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 24px;
    }
    .health-bar span { font-size: 0.83rem; }
    .health-bar .status { font-weight: 600; }
    .health-bar .ts { color: var(--muted); font-size: 0.75rem; margin-left: auto; font-family: monospace; }

    @media (max-width: 600px) {
      .topnav { padding: 0 14px; }
      .nav-link span { display: none; }
      .page { padding: 20px 14px 48px; }
    }
  </style>
</head>
