<script>
  fetch('/health').then(r=>r.json()).then(d=>{
    document.getElementById('navEnv').textContent = d.status === 'ok' ? '● Online' : '● Offline';
    document.getElementById('navEnv').style.color = d.status === 'ok' ? '#86efac' : '#f87171';
  }).catch(()=>{
    document.getElementById('navEnv').textContent = '● Offline';
    document.getElementById('navEnv').style.color = '#f87171';
  });
</script>
